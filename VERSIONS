# AbX2T bundle versions -- single source of truth.
# Every ONLYOFFICE component in this repo (x2t, sdkjs, vendored core sources in
# allfontsgen/, core-master/ checkout) and the release tags of AbX2T itself align
# on these values. Bump them together when upgrading, then re-run the fetch
# scripts (build/fetch_onlyoffice_*) and rebuild.

# DesktopEditors release tag (3 components) -- used to build the download URLs:
# https://github.com/ONLYOFFICE/DesktopEditors/releases/tag/v<ONLYOFFICE_VERSION>
ONLYOFFICE_VERSION=9.4.0

# Matching core/sdkjs build (4 components) -- tags on ONLYOFFICE/core and
# ONLYOFFICE/sdkjs; this is the version x2t reports and the AGPL source pointer.
ONLYOFFICE_CORE_BUILD=9.4.0.129

# SHA-256 of the official release artifacts, one per platform. Fill these in when
# bumping ONLYOFFICE_VERSION: run the fetch script once, copy the hash it prints.
# Empty value = the fetch script prints the downloaded file's hash instead of
# failing, so a new version can be bootstrapped.
SHA256_MACOS_DMG=e965be2222609add6b5a70baa2a8cdb599402491fb2925825d9039dcb154beb4
SHA256_LINUX_DEB=4271434e81be42b1559fd989d24bf6d413482f278dc6a5e328202a4fc1a18649
SHA256_WINDOWS_ZIP=22ae48a7813954e5079bff1ea211c6583aba67f34f2d0dbcb2431d4a20e94dfc
